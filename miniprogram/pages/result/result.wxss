page {
  background-color: #0f0f1a;
}

.container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  padding: 24rpx 32rpx;
  padding-bottom: 60rpx;
  box-sizing: border-box;
}

/* ── Loading State ── */

.loading-container {
  align-items: center;
  justify-content: center;
}

.loading-spinner {
  width: 64rpx;
  height: 64rpx;
  border: 4rpx solid #252540;
  border-top-color: #e8b86d;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 24rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-hint {
  color: #8a8a8a;
  font-size: 28rpx;
}

/* ── Section ── */

.section {
  margin-bottom: 36rpx;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.section-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #8a8a8a;
  text-transform: uppercase;
  letter-spacing: 2rpx;
}

/* ── Copy Button (inline) ── */

.copy-btn {
  padding: 8rpx 20rpx;
  background: #252540;
  border-radius: 24rpx;
}

.copy-btn-text {
  font-size: 24rpx;
  color: #e8b86d;
}

/* ── Title Card ── */

.title-card {
  background: #1a1a2e;
  border-radius: 16rpx;
  padding: 28rpx 24rpx;
  border: 1rpx solid #252540;
}

.title-text {
  font-size: 36rpx;
  font-weight: 700;
  color: #e8b86d;
  line-height: 1.5;
}

/* ── Content Card ── */

.content-card {
  background: #1a1a2e;
  border-radius: 16rpx;
  padding: 28rpx 24rpx;
  border: 1rpx solid #252540;
}

.content-text {
  font-size: 30rpx;
  color: #e0e0e0;
  line-height: 1.8;
  white-space: pre-wrap;
  word-break: break-all;
}

/* ── Tags ── */

.tags-wrap {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.tag-pill {
  display: inline-flex;
  align-items: center;
  padding: 10rpx 24rpx;
  background: #252540;
  border-radius: 32rpx;
  border: 1rpx solid rgba(232, 184, 109, 0.25);
}

.tag-text {
  font-size: 26rpx;
  color: #f0c878;
}

/* ── Bottom Actions ── */

.actions {
  margin-top: 20rpx;
  padding-bottom: env(safe-area-inset-bottom);
}

.action-btn {
  width: 100%;
  height: 92rpx;
  line-height: 92rpx;
  text-align: center;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 46rpx;
  border: none;
  margin-bottom: 20rpx;
}

.action-btn::after {
  border: none;
}

.action-btn.primary {
  background: linear-gradient(135deg, #e8b86d, #f0c878);
  color: #0f0f1a;
}

.action-row {
  display: flex;
  gap: 20rpx;
}

.action-row .action-btn {
  flex: 1;
  width: auto;
}

.action-btn.secondary {
  background: #1a1a2e;
  color: #e0e0e0;
  border: 1rpx solid #252540;
}
