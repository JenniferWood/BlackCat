.page {
  min-height: 100vh;
  background-color: #0f0f1a;
  padding-bottom: 160rpx;
}

/* ===== Filter Bar ===== */
.filter-bar {
  padding: 24rpx 0 0;
  white-space: nowrap;
}

.filter-list {
  display: inline-flex;
  gap: 16rpx;
  padding: 0 32rpx 20rpx;
}

.filter-chip {
  display: inline-flex;
  align-items: center;
  padding: 12rpx 28rpx;
  border-radius: 32rpx;
  background-color: #1a1a2e;
  border: 2rpx solid transparent;
  flex-shrink: 0;
}

.filter-chip--active {
  background-color: rgba(232, 184, 109, 0.15);
  border-color: #e8b86d;
}

.filter-chip-text {
  font-size: 26rpx;
  color: #8a8a8a;
  white-space: nowrap;
}

.filter-chip--active .filter-chip-text {
  color: #e8b86d;
  font-weight: 600;
}

.filter-chip--fav .filter-chip-text {
  letter-spacing: 2rpx;
}

/* ===== Search Bar ===== */
.search-bar {
  padding: 0 32rpx 24rpx;
}

.search-input-wrap {
  display: flex;
  align-items: center;
  background-color: #1a1a2e;
  border-radius: 16rpx;
  padding: 0 24rpx;
  height: 80rpx;
}

.search-icon {
  font-size: 28rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #e0e0e0;
  height: 80rpx;
}

.search-clear {
  flex-shrink: 0;
  padding: 8rpx;
  margin-left: 8rpx;
}

.search-clear-icon {
  font-size: 28rpx;
  color: #8a8a8a;
}

/* ===== Loading ===== */
.loading-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 160rpx 0;
}

.loading-spinner {
  width: 56rpx;
  height: 56rpx;
  border: 4rpx solid #1a1a2e;
  border-top-color: #e8b86d;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

.loading-spinner--small {
  width: 36rpx;
  height: 36rpx;
  border-width: 3rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 24rpx;
  font-size: 26rpx;
  color: #8a8a8a;
}

/* ===== Error ===== */
.error-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 160rpx 0;
}

.error-text {
  font-size: 28rpx;
  color: #8a8a8a;
}

/* ===== Empty State ===== */
.empty-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 160rpx 40rpx;
}

.empty-emoji {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 30rpx;
  color: #8a8a8a;
  margin-bottom: 32rpx;
}

.empty-btn {
  background-color: #e8b86d;
  padding: 16rpx 48rpx;
  border-radius: 32rpx;
}

.empty-btn-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #0f0f1a;
}

/* ===== Grid Info ===== */
.grid-info {
  padding: 0 32rpx 16rpx;
}

.grid-count {
  font-size: 24rpx;
  color: #8a8a8a;
}

/* ===== Media Grid ===== */
.media-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  padding: 0 32rpx;
}

.media-card {
  width: calc(50% - 6rpx);
  position: relative;
  border-radius: 16rpx;
  overflow: hidden;
  background-color: #1a1a2e;
}

.media-thumb {
  width: 100%;
  height: 340rpx;
  display: block;
}

/* Favorite heart */
.media-fav {
  position: absolute;
  top: 12rpx;
  left: 12rpx;
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: rgba(15, 15, 26, 0.6);
  border-radius: 50%;
}

.media-fav-icon {
  font-size: 28rpx;
  color: #e8b86d;
}

/* Status dot */
.media-status-dot {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(15, 15, 26, 0.5);
}

.status-uploaded {
  background-color: #8a8a8a;
}

.status-analyzed {
  background-color: #42a5f5;
}

.status-recommended {
  background-color: #e8b86d;
}

.status-published {
  background-color: #4caf50;
}

/* Bottom mood overlay */
.media-bottom {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 16rpx 16rpx 14rpx;
  background: linear-gradient(transparent, rgba(15, 15, 26, 0.85));
}

.media-mood {
  font-size: 22rpx;
  color: #e0e0e0;
  display: -webkit-box;
  -webkit-line-clamp: 1;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

/* Publish score badge */
.media-score-badge {
  position: absolute;
  top: 12rpx;
  right: 40rpx;
  background-color: rgba(15, 15, 26, 0.7);
  border-radius: 12rpx;
  padding: 4rpx 14rpx;
}

.media-score-text {
  font-size: 22rpx;
  font-weight: 600;
  color: #e8b86d;
}

/* ===== Load More ===== */
.load-more {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 32rpx 0;
}

.load-more-text {
  font-size: 24rpx;
  color: #8a8a8a;
}

.no-more {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx 0;
}

.no-more-text {
  font-size: 24rpx;
  color: #555;
}
