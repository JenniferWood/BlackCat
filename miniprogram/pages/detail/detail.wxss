.page {
  min-height: 100vh;
  background-color: #0f0f1a;
  padding-bottom: 80rpx;
}

/* ===== Loading / Error ===== */
.loading-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
}

.loading-spinner {
  width: 56rpx;
  height: 56rpx;
  border: 4rpx solid #1a1a2e;
  border-top-color: #e8b86d;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 24rpx;
  font-size: 26rpx;
  color: #8a8a8a;
}

.error-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
}

.error-text {
  font-size: 28rpx;
  color: #8a8a8a;
}

/* ===== Hero Image ===== */
.hero {
  position: relative;
  width: 100%;
  background-color: #1a1a2e;
}

.hero-image {
  width: 100%;
  display: block;
  max-height: 800rpx;
}

.hero-hint {
  position: absolute;
  bottom: 16rpx;
  right: 16rpx;
  background-color: rgba(15, 15, 26, 0.6);
  border-radius: 8rpx;
  padding: 6rpx 16rpx;
}

.hero-hint-text {
  font-size: 22rpx;
  color: #8a8a8a;
}

/* ===== Action Bar ===== */
.action-bar {
  display: flex;
  align-items: center;
  justify-content: space-around;
  padding: 24rpx 32rpx;
  background-color: #1a1a2e;
  border-bottom: 2rpx solid rgba(138, 138, 138, 0.1);
}

.action-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 24rpx;
  border-radius: 12rpx;
}

.action-btn:active {
  background-color: rgba(255, 255, 255, 0.05);
}

.action-icon {
  font-size: 40rpx;
}

.action-label {
  font-size: 22rpx;
  color: #8a8a8a;
}

.action-btn--fav .action-icon {
  color: #e8b86d;
}

.action-btn--compose .action-icon {
  color: #4caf50;
}

.action-btn--delete .action-icon {
  color: #e74c3c;
}

/* ===== Sections ===== */
.section {
  margin-top: 24rpx;
  padding: 0 32rpx;
}

.section-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #e0e0e0;
}

/* ===== Analysis ===== */
.analysis-block {
  margin-bottom: 28rpx;
}

.analysis-label {
  display: block;
  font-size: 24rpx;
  color: #8a8a8a;
  margin-bottom: 8rpx;
}

.analysis-desc {
  display: block;
  font-size: 28rpx;
  color: #e0e0e0;
  line-height: 1.7;
}

/* Tags */
.tag-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.tag-pill {
  background-color: rgba(232, 184, 109, 0.15);
  border: 2rpx solid rgba(232, 184, 109, 0.3);
  border-radius: 24rpx;
  padding: 8rpx 24rpx;
}

.tag-text {
  font-size: 24rpx;
  color: #e8b86d;
}

/* Mood */
.analysis-mood {
  display: block;
  font-size: 28rpx;
  color: #e0e0e0;
}

/* Score bars */
.score-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.score-bar-bg {
  flex: 1;
  height: 16rpx;
  background-color: #1a1a2e;
  border-radius: 8rpx;
  overflow: hidden;
}

.score-bar-fill {
  height: 100%;
  border-radius: 8rpx;
  transition: width 0.3s ease;
}

.score-bar-fill--quality {
  background: linear-gradient(90deg, #42a5f5, #66bb6a);
}

.score-bar-fill--publish {
  background: linear-gradient(90deg, #e8b86d, #f0c878);
}

.score-value {
  font-size: 26rpx;
  font-weight: 600;
  color: #e0e0e0;
  min-width: 80rpx;
  text-align: right;
}

/* No analysis */
.no-analysis {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 0;
  background-color: #1a1a2e;
  border-radius: 16rpx;
}

.no-analysis-text {
  font-size: 28rpx;
  color: #8a8a8a;
  margin-bottom: 24rpx;
}

.analyze-btn {
  background-color: #e8b86d;
  padding: 14rpx 48rpx;
  border-radius: 28rpx;
}

.analyze-btn-text {
  font-size: 26rpx;
  font-weight: 600;
  color: #0f0f1a;
}

/* ===== Info Section ===== */
.info-list {
  background-color: #1a1a2e;
  border-radius: 16rpx;
  overflow: hidden;
}

.info-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 28rpx;
  border-bottom: 2rpx solid rgba(138, 138, 138, 0.08);
}

.info-row:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 26rpx;
  color: #8a8a8a;
}

.info-value {
  font-size: 26rpx;
  color: #e0e0e0;
}

/* Status badge */
.status-badge {
  padding: 6rpx 20rpx;
  border-radius: 16rpx;
}

.status-badge-text {
  font-size: 22rpx;
  font-weight: 600;
}

.status-uploaded {
  background-color: rgba(138, 138, 138, 0.15);
}

.status-uploaded .status-badge-text {
  color: #8a8a8a;
}

.status-analyzed {
  background-color: rgba(66, 165, 245, 0.15);
}

.status-analyzed .status-badge-text {
  color: #42a5f5;
}

.status-recommended {
  background-color: rgba(232, 184, 109, 0.15);
}

.status-recommended .status-badge-text {
  color: #e8b86d;
}

.status-published {
  background-color: rgba(76, 175, 80, 0.15);
}

.status-published .status-badge-text {
  color: #4caf50;
}
