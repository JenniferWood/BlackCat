<view class="container">
  <!-- Loading Overlay -->
  <view class="loading-overlay" wx:if="{{generating}}">
    <view class="loading-card">
      <view class="loading-spinner"></view>
      <text class="loading-text">皮蛋正在创作中...</text>
    </view>
  </view>

  <!-- Section: 选择素材 -->
  <view class="section">
    <view class="section-header">
      <text class="section-title">选择素材</text>
      <text class="section-count">已选 {{selectedIds.length}}/{{maxSelect}} 个</text>
    </view>

    <scroll-view
      class="media-strip"
      scroll-x="{{true}}"
      enable-flex="{{true}}"
      wx:if="{{mediaList.length > 0}}"
    >
      <view
        class="media-item {{selectedIds.indexOf(item.id) > -1 ? 'selected' : ''}}"
        wx:for="{{mediaList}}"
        wx:key="id"
        data-id="{{item.id}}"
        bindtap="selectMedia"
      >
        <image
          class="media-thumb"
          src="{{item.thumbnailUrl || item.blobUrl}}"
          mode="aspectFill"
        />
        <view class="check-badge" wx:if="{{selectedIds.indexOf(item.id) > -1}}">
          <text class="check-icon">✓</text>
        </view>
        <view class="video-badge" wx:if="{{item.type === 'video'}}">
          <text class="video-icon">▶</text>
        </view>
      </view>
    </scroll-view>

    <view class="empty-hint" wx:if="{{mediaList.length === 0}}">
      <text class="empty-text">暂无已分析的素材，请先上传</text>
    </view>
  </view>

  <!-- Section: 选择风格 -->
  <view class="section">
    <view class="section-header">
      <text class="section-title">选择风格</text>
    </view>

    <view class="style-grid">
      <view
        class="style-card {{selectedStyle === item.key ? 'selected' : ''}}"
        wx:for="{{styles}}"
        wx:key="key"
        data-style="{{item.key}}"
        bindtap="selectStyle"
      >
        <text class="style-emoji">{{item.emoji}}</text>
        <text class="style-label">{{item.label}}</text>
      </view>
    </view>
  </view>

  <!-- Generate Button -->
  <view class="bottom-action">
    <button
      class="generate-btn {{selectedIds.length === 0 ? 'disabled' : ''}}"
      disabled="{{selectedIds.length === 0 || generating}}"
      bindtap="generate"
    >
      <text wx:if="{{!generating}}">生成文案 ✨</text>
      <text wx:else>生成中...</text>
    </button>
  </view>
</view>
