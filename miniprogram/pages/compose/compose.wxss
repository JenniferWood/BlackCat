page {
  background-color: #0f0f1a;
}

.container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  padding: 24rpx 32rpx;
  padding-bottom: 180rpx;
  box-sizing: border-box;
}

/* ── Loading Overlay ── */

.loading-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(15, 15, 26, 0.85);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}

.loading-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 64rpx 80rpx;
  background: #1a1a2e;
  border-radius: 24rpx;
  border: 1rpx solid #252540;
}

.loading-spinner {
  width: 64rpx;
  height: 64rpx;
  border: 4rpx solid #252540;
  border-top-color: #e8b86d;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 32rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  color: #e8b86d;
  font-size: 30rpx;
  font-weight: 500;
}

/* ── Section ── */

.section {
  margin-bottom: 40rpx;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #e0e0e0;
}

.section-count {
  font-size: 26rpx;
  color: #e8b86d;
  font-weight: 500;
}

/* ── Media Strip ── */

.media-strip {
  white-space: nowrap;
  width: 100%;
  height: 200rpx;
}

.media-item {
  display: inline-block;
  position: relative;
  width: 180rpx;
  height: 180rpx;
  margin-right: 16rpx;
  border-radius: 16rpx;
  overflow: hidden;
  border: 3rpx solid transparent;
  box-sizing: border-box;
  transition: border-color 0.2s ease;
  flex-shrink: 0;
}

.media-item.selected {
  border-color: #e8b86d;
  box-shadow: 0 0 12rpx rgba(232, 184, 109, 0.4);
}

.media-thumb {
  width: 100%;
  height: 100%;
}

.check-badge {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 40rpx;
  height: 40rpx;
  background: #e8b86d;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.check-icon {
  color: #0f0f1a;
  font-size: 22rpx;
  font-weight: 700;
}

/* ── Empty Hint ── */

.empty-hint {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 180rpx;
  background: #1a1a2e;
  border-radius: 16rpx;
  border: 1rpx dashed #252540;
}

.empty-text {
  color: #8a8a8a;
  font-size: 28rpx;
}

/* ── Style Grid ── */

.style-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
}

.style-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 32rpx 16rpx;
  background: #1a1a2e;
  border-radius: 16rpx;
  border: 2rpx solid #252540;
  transition: all 0.2s ease;
}

.style-card.selected {
  border-color: #e8b86d;
  background: #252540;
  box-shadow: 0 0 16rpx rgba(232, 184, 109, 0.25);
}

.style-emoji {
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.style-label {
  font-size: 28rpx;
  color: #e0e0e0;
  font-weight: 500;
}

.style-card.selected .style-label {
  color: #e8b86d;
}

/* ── Bottom Action ── */

.bottom-action {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background: linear-gradient(to top, #0f0f1a 60%, transparent);
}

.generate-btn {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  text-align: center;
  background: linear-gradient(135deg, #e8b86d, #f0c878);
  color: #0f0f1a;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 48rpx;
  border: none;
  letter-spacing: 2rpx;
}

.generate-btn::after {
  border: none;
}

.generate-btn.disabled {
  background: #252540;
  color: #8a8a8a;
}
